<%
  const footerMoreVars = [
    {
      name: '{thisYear}',
      desc: '今年年份',
      func: () => {
        return new Date().getFullYear()
      }
    }
  ]
%>
<div class="footer">
  <% const defaultLanguage = oranges_default_language(); %>
  <div class="social">
    <ul>
      <% for (let item of theme.footer.social) { %>
        <li>
          <% if (item.name==='email' ) { %>
            <a title="<%- item.name %>" href="mailto:<%- item.path %>">
              <i class="iconfont icon-<%- item.icon %>"></i>
            </a>
            <% } else { %>
              <a title="<%- item.name %>" href="<%- item.path %>">
                <i class="iconfont icon-<%- item.icon %>"></i>
              </a>
              <% } %>
        </li>
        <% } %>
    </ul>
  </div>
  <% for(let item of theme.footer.more){ %>
    <%
      let footerMoreName = oranges_localize(item.name, defaultLanguage)
      footerMoreVars.forEach(i => {
        if (footerMoreName.includes(i.name)) {
          footerMoreName = footerMoreName.replace(i.name, i.func)
        }
      })
    %>
    <div class="footer-more">
      <% if (item.path) { %>
        <a href="<%- item.path %>" data-l10n="<%- oranges_localize_attr_json(item.name) %>"><%- footerMoreName %></a>
      <% } else { %>
        <span data-l10n="<%- oranges_localize_attr_json(item.name) %>"><%- footerMoreName %></span>
      <% } %>  
    </div>
  <% } %>
  <% if (theme.footer.views && theme.footer.views.enable) { %>
    <div class="footer-views">
      <% for(let item of theme.footer.views.item) {
        if (item.enable) { %>
          <%- item.name %><span id="<%- item.id %>"></span><%- item.unit %>
        <% } %>
      <% } %>
    </div>
  <% } %>
</div>
