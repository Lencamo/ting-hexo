<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="author" content="<%= config.author %>" />
  <!-- Open Graph Description 简短摘要-->
  <% if (page.ogdescription){ %>
  <!-- 文章页 -->
  <meta property="og:description" content="<%= page.ogdescription %>" />
  <% } %>
  <!-- 用于搜索引擎的文章摘要 -->
  <% if (page.description){ %>
  <!-- 文章页 -->
  <meta name="description" content="<%= page.description %>" />
  <% } else if (config.description){ %>
  <meta name="description" content="<%= config.description %>" />
  <%} %>
  <% if(is_home() && page.current > 1){ %>
    <meta name="robots" content="noindex" />
  <% } %>
  <%
    const defaultLanguage = oranges_default_language();
    const siteTitle = (theme.avatar && theme.avatar.author_nickname) || config.title;
    var title = page.title;

    if (is_archive()){
      title = 'archive_a';

      if (is_month()){
        title += ': ' + page.year + '/' + page.month;
      } else if (is_year()){
        title += ': ' + page.year;
      }
    } else if (is_category() || title === "categories"){
      title = "category"
    } else if (is_tag() || title === "tags"){
      title = "tag"
    } else if (title === "friends") {
      title = "friend"
    } else if (title === "about") {
      title = "about"
    }
  %>
  <title>
    <% if (title) { %>
      <%= oranges_translate(title, defaultLanguage) %> 
      <% if (page.tag) { %> : <%= page.tag %><% } %>
      <% if (page.category) { %> : <%= page.category %><% } %>
      |
    <% } %>
     <%= oranges_localize(siteTitle, defaultLanguage) %>
  </title>

  <% if (theme.favicon.enable){ %>
    <link rel="apple-touch-icon" href="<%- theme.favicon.touch_icon %>">
    <link rel="icon" href="<%- theme.favicon.icon %>">
  <% } %>

  <!-- Raleway-Font -->
  <link href="https://fonts.googleapis.com/css?family=Raleway&display=swap" rel="stylesheet">

  <!-- hexo site css -->
  <link rel="stylesheet" href="/css/main.css" />
  <link rel="stylesheet" href="//at.alicdn.com/t/font_1886449_67xjft27j1l.css" />
  <!-- 代码块风格 -->
  <% if (theme.codeBlock && theme.codeBlock.style && theme.codeBlock.style == 'mac-black'){ %>
    <%- css(['/css/figcaption/mac-block.css'])%>
  <% } %>

  <!-- jquery3.3.1 -->
  <% if (theme.cdns && theme.cdns.jquery && theme.cdns.jquery.enable) { %>
    <script defer type="text/javascript" src="<%- theme.cdns.jquery.url %>"></script>
  <% } else { %>
    <script defer type="text/javascript" src="/plugins/jquery.min.js"></script>
  <% } %>

  <!-- fancybox -->
  <% if (theme.cdns && theme.cdns.fancybox && theme.cdns.fancybox.enable) { %>
    <link href="<%- theme.cdns.fancybox.url.css %>" rel="stylesheet">
    <script defer type="text/javascript" src="<%- theme.cdns.fancybox.url.js %>"></script>
  <% } else { %>
    <link href="/plugins/jquery.fancybox.min.css" rel="stylesheet">
    <script defer type="text/javascript" src="/plugins/jquery.fancybox.min.js"></script>
  <% } %>
  <%- js(['/js/fancybox.js']) %>

  <% if(theme.gtag.enable) { %>
    <!-- Global site tag (gtag.js) - Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=<%- theme.gtag.gtagkey %>"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', '<%- theme.gtag.gtagkey %>');
    </script>
  <% } %>

  <% if (theme.footer.views && theme.footer.views.enable) { %>
    <script async src="<%- theme.footer.views.provider %>"></script>
  <% } %>

  <script>
    window.__ORANGES_SITE_TITLE__ = <%- oranges_localize_json(siteTitle) %>
    window.__ORANGES_DEFAULT_LANGUAGE__ = '<%- oranges_default_language() %>'
    window.__ORANGES_LANGUAGES__ = <%- oranges_language_options_json() %>
    window.__ORANGES_I18N__ = <%- oranges_i18n_json([
      'home',
      'archives',
      'tags',
      'categories',
      'about',
      'friend',
      'friends',
      'search',
      'searchFirst',
      'searchNoResult',
      'searchFilesNotfound',
      'searchServiceErrors',
      'configuration',
      'catalog',
      'prev',
      'next',
      'updateTime',
      'pinned',
      'untitled'
    ]) %>

    var html = document.documentElement
    const uiLanguage = localStorage.getItem('ui-language-v2') || window.__ORANGES_DEFAULT_LANGUAGE__
    document.documentElement.setAttribute('ui-lang', uiLanguage)
    document.documentElement.lang = uiLanguage
    const colorMode = localStorage.getItem('color-mode') || 'dark'
    document.documentElement.setAttribute('color-mode', colorMode)

    function updateSiteTitle(lang) {
      const siteTitleMap = window.__ORANGES_SITE_TITLE__ || {}
      const nextSiteTitle = siteTitleMap[lang] || siteTitleMap[window.__ORANGES_DEFAULT_LANGUAGE__] || ''

      if (!nextSiteTitle) return

      const separator = ' | '
      const index = document.title.lastIndexOf(separator)

      if (index === -1) {
        document.title = nextSiteTitle
        return
      }

      document.title = document.title.slice(0, index + separator.length) + nextSiteTitle
    }

    updateSiteTitle(uiLanguage)
    document.addEventListener('oranges:languagechange', function(event) {
      updateSiteTitle(event.detail.lang)
    })
  </script>
</head>
